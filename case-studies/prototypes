<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ACV APEX VDP Navigation Demo</title>
<style>
  body { margin: 0; padding: 30px 20px; background: #0a0a0a; min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif; }
  .stage { background: #1a1a1a; border-radius: 28px; padding: 28px; display: flex; flex-direction: column; align-items: center; gap: 18px; }
  .phone { width: 320px; height: 680px; background: #000; border-radius: 36px; border: 7px solid #2a2a2a; overflow: hidden; position: relative; }
  .phone * { box-sizing: border-box; }
  .phone svg { display: inline-block; flex-shrink: 0; }

  .screen { position: absolute; inset: 0; opacity: 0; pointer-events: none; transition: opacity 380ms ease; display: flex; flex-direction: column; }
  .screen.on { opacity: 1; pointer-events: auto; }

  .light-head { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; border-bottom: 0.5px solid #eee; background: #fff; flex-shrink: 0; }
  .logo-wrap { display: flex; flex-direction: column; align-items: flex-start; line-height: 1; }
  .logo-acv { font-family: "Arial Black", Impact, sans-serif; font-weight: 900; font-size: 26px; color: #E85D2F; letter-spacing: -1.5px; line-height: 0.82; font-style: italic; display: inline-block; transform: skewX(-6deg); }
  .logo-sub { font-family: "Arial Black", Impact, sans-serif; font-weight: 900; font-size: 8px; color: #1A2B4A; letter-spacing: 1.2px; line-height: 1; margin-top: 2px; font-style: italic; display: inline-block; transform: skewX(-6deg); }
  .head-icons { display: flex; align-items: center; gap: 14px; color: #444; position: relative; }
  .head-icons .bell-wrap { position: relative; display: flex; align-items: center; }
  .head-icons .bell-dot { position: absolute; top: -1px; right: -2px; width: 7px; height: 7px; background: #ff7a1f; border-radius: 50%; border: 1px solid #fff; }
  .bottom-nav { display: flex; justify-content: space-around; border-top: 0.5px solid #eee; padding: 6px 0 8px; background: #fff; flex-shrink: 0; }
  .nav-item { display: flex; flex-direction: column; align-items: center; gap: 2px; font-size: 9px; color: #888; }
  .nav-item.active { color: #ff7a1f; }

  /* Results screen */
  .results { background: #f7f7f9; color: #111; }
  .results-body { flex: 1; padding: 14px 14px 8px; display: flex; flex-direction: column; overflow: hidden; position: relative; }
  .results-title { font-size: 14px; font-weight: 700; color: #0d0d0d; margin: 0 0 3px; line-height: 1.25; letter-spacing: -0.2px; }
  .results-subtitle { font-size: 10.5px; color: #666; margin: 0 0 11px; }
  .results-actions { display: flex; gap: 8px; margin-bottom: 11px; }
  .action-btn { flex: 1; background: #fff; border: 0.5px solid #ddd; border-radius: 10px; padding: 8px 10px; display: flex; align-items: center; justify-content: center; gap: 6px; font-size: 11px; font-weight: 600; color: #111; }
  .results-tabs { background: #e8eaee; border-radius: 999px; padding: 3px; display: flex; margin-bottom: 12px; }
  .tab { flex: 1; text-align: center; padding: 5px 4px; font-size: 10px; color: #777; border-radius: 999px; }
  .tab.active { background: #fff; color: #111; font-weight: 600; }
  .opp-card { background: #fff4ec; border: 1px solid #ffb380; border-radius: 12px; padding: 11px; margin-bottom: 11px; }
  .opp-top { display: flex; gap: 9px; align-items: flex-start; margin-bottom: 8px; }
  .opp-icon-circle { width: 26px; height: 26px; background: #ff7a1f; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; }
  .opp-title-wrap { flex: 1; min-width: 0; }
  .opp-title { font-size: 11.5px; font-weight: 700; color: #111; line-height: 1.25; }
  .opp-success { background: #e6f4e6; border-radius: 8px; padding: 5px 7px; text-align: center; flex-shrink: 0; }
  .opp-success-label { font-size: 7.5px; color: #2d7a2d; font-weight: 600; display: flex; align-items: center; gap: 3px; justify-content: center; }
  .opp-rate { font-size: 15px; font-weight: 800; color: #2d7a2d; line-height: 1.1; }
  .opp-sub { font-size: 7.5px; color: #2d7a2d; }
  .opp-bullets { margin: 0 0 10px; padding: 0; list-style: none; }
  .opp-bullet { display: flex; align-items: flex-start; gap: 6px; font-size: 10px; color: #333; padding: 1.5px 0; line-height: 1.3; }
  .opp-check { color: #2d7a2d; flex-shrink: 0; margin-top: 1px; }
  .view-details-btn { background: #ff7a1f; color: #fff; border: none; border-radius: 8px; padding: 9px; width: 100%; text-align: center; font-size: 12px; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 6px; position: relative; font-family: inherit; }
  .vdp-tap-ripple { position: absolute; top: 50%; left: 50%; width: 22px; height: 22px; border-radius: 50%; transform: translate(-50%, -50%) scale(0); border: 1.5px solid #ff7a1f; background: rgba(255,255,255,0.4); opacity: 0; pointer-events: none; }
  .vdp-tap-ripple.go { animation: tapRipple 0.7s ease-out forwards; }
  .view-details-btn.pressed { animation: btnPress 0.4s ease-out; }
  @keyframes btnPress { 0%,100% { transform: scale(1); } 40% { transform: scale(0.96); filter: brightness(0.92); } }
  .results-count-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 7px; }
  .results-count-num { font-size: 12px; font-weight: 700; color: #111; }
  .sort-dropdown { background: #fff; border: 0.5px solid #ddd; border-radius: 10px; padding: 9px 12px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; font-size: 11px; font-weight: 600; color: #111; }
  .result-card { background: #fff; border: 0.5px solid #eee; border-radius: 10px; padding: 8px; display: flex; gap: 9px; }
  .result-thumb { width: 60px; height: 70px; border-radius: 6px; flex-shrink: 0; background: #2a2a2a; overflow: hidden; }
  .result-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .result-mid { flex: 1; min-width: 0; }
  .result-name { font-size: 11px; font-weight: 700; color: #111; margin-bottom: 2px; }
  .result-meta { font-size: 9.5px; color: #666; line-height: 1.5; }
  .blue-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #2d7df0; vertical-align: middle; margin: 0 3px; }
  .result-loc { display: flex; align-items: center; gap: 3px; font-size: 9.5px; color: #666; margin-top: 2px; }
  .result-right { display: flex; flex-direction: column; align-items: flex-end; justify-content: space-between; flex-shrink: 0; gap: 6px; }
  .result-action-icons { display: flex; gap: 8px; color: #999; }
  .result-time { display: flex; align-items: center; gap: 3px; font-size: 9px; color: #555; }
  .result-price-label { font-size: 8.5px; color: #888; text-align: right; }
  .result-price-val { font-size: 13px; font-weight: 700; color: #111; text-align: right; }
  .chat-fab { position: absolute; bottom: 50px; right: 12px; width: 48px; height: 48px; background: #ff7a1f; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #fff; font-size: 7px; font-weight: 700; z-index: 5; }

  /* VDP screen */
  .vdp { background: #f7f7f9; color: #111; }
  .vdp-scroll-wrap { flex: 1; overflow: hidden; position: relative; }
  .vdp-body { padding: 12px 12px 14px; transition: transform 1400ms cubic-bezier(0.4, 0, 0.2, 1); }
  .vdp-body.slow { transition: transform 2400ms cubic-bezier(0.45, 0.05, 0.25, 1); }
  .vdp-body.s1 { transform: translateY(-230px); }
  .vdp-body.s2 { transform: translateY(-540px); }

  .vdp-summary { background: #fff4ec; border: 1px solid #ffb380; border-radius: 12px; padding: 10px; margin-bottom: 12px; display: flex; gap: 8px; }
  .vdp-summary-icon { width: 22px; height: 22px; background: #ff7a1f; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; }
  .vdp-summary-body { flex: 1; min-width: 0; }
  .vdp-summary-title { font-size: 10.5px; font-weight: 700; color: #111; margin-bottom: 4px; }
  .vdp-summary-item { font-size: 9.5px; color: #333; line-height: 1.5; display: flex; gap: 4px; }
  .vdp-summary-item::before { content: '•'; color: #777; }
  .vdp-summary-right { display: flex; flex-direction: column; gap: 8px; align-items: stretch; flex-shrink: 0; width: 104px; }
  .vdp-stat-row { display: flex; gap: 16px; justify-content: space-between; padding: 0 2px; }
  .vdp-stat { flex: 1; text-align: center; }
  .vdp-stat-label { font-size: 7.5px; color: #555; font-weight: 600; display: flex; align-items: center; gap: 2px; justify-content: center; }
  .vdp-stat-val { font-size: 14px; font-weight: 800; line-height: 1.1; margin-top: 1px; }
  .vdp-stat-val.green { color: #2d7a2d; }
  .vdp-stat-val.orange { color: #ff7a1f; }
  .vdp-place-btn { background: #ff7a1f; color: #fff; border: none; border-radius: 7px; padding: 7px; font-size: 10px; font-weight: 700; font-family: inherit; }

  .vdp-gallery { background: #2a2a2a; border-radius: 12px; height: 150px; margin-bottom: 8px; position: relative; overflow: hidden; }
  .vdp-gallery img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .vdp-active-badge { position: absolute; top: 10px; left: 10px; background: #34d399; color: #064e3b; font-size: 8.5px; font-weight: 800; padding: 4px 8px; border-radius: 5px; letter-spacing: 0.4px; z-index: 2; }
  .vdp-page-num { position: absolute; bottom: 9px; right: 9px; background: rgba(0,0,0,0.55); color: #fff; font-size: 9px; padding: 3px 7px; border-radius: 4px; font-weight: 600; z-index: 2; }
  .vdp-thumbs { display: flex; gap: 5px; margin-bottom: 14px; }
  .vdp-thumb { flex: 1; height: 38px; border-radius: 5px; background: #2a2a2a; overflow: hidden; position: relative; }
  .vdp-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .vdp-thumb.t0 { outline: 2px solid #ff7a1f; outline-offset: -2px; z-index: 1; }

  .vdp-tabs { display: flex; background: #e8eaee; border-radius: 10px; padding: 3px; margin-bottom: 12px; }
  .vdp-tab { flex: 1; text-align: center; padding: 7px 4px; font-size: 10.5px; color: #777; border-radius: 8px; font-weight: 500; }
  .vdp-tab.active { background: #fff; color: #111; font-weight: 700; box-shadow: 0 1px 2px rgba(0,0,0,0.06); }

  .vdp-details-card { background: #fff; border: 0.5px solid #eee; border-radius: 10px; padding: 12px; margin-bottom: 10px; }
  .vdp-details-title { font-size: 12px; font-weight: 700; color: #111; margin-bottom: 10px; }
  .vdp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 12px; margin-bottom: 12px; }
  .vdp-field-label { font-size: 9px; color: #777; margin-bottom: 2px; }
  .vdp-field-val { font-size: 10.5px; font-weight: 600; color: #111; display: flex; gap: 4px; align-items: center; }
  .vdp-features-title { font-size: 10.5px; font-weight: 600; color: #111; margin-bottom: 6px; }
  .vdp-features-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5px 8px; }
  .vdp-feature { display: flex; align-items: center; gap: 4px; font-size: 9.5px; color: #222; }
  .vdp-feature-check { color: #2d7a2d; flex-shrink: 0; }

  .vdp-bid-card { background: #fff; border: 0.5px solid #eee; border-radius: 10px; padding: 14px; margin-bottom: 8px; }
  .vdp-bid-head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 4px; gap: 8px; }
  .vdp-bid-title { font-size: 13px; font-weight: 800; color: #111; line-height: 1.3; }
  .vdp-bid-sub { font-size: 9.5px; color: #666; margin-bottom: 16px; line-height: 1.4; }
  .vdp-bid-icons { display: flex; gap: 6px; flex-shrink: 0; }
  .vdp-bid-icons .ico { width: 22px; height: 22px; border-radius: 50%; background: #f3f4f6; display: flex; align-items: center; justify-content: center; color: #555; }
  .vdp-bid-label { font-size: 10px; color: #666; margin-bottom: 5px; line-height: 1.4; }
  .vdp-bid-amt { font-size: 21px; font-weight: 900; color: #0d1f4f; line-height: 1.15; margin: 0 0 6px; letter-spacing: -0.5px; }
  .vdp-bid-count { font-size: 10px; color: #666; margin-bottom: 14px; line-height: 1.4; }
  .vdp-time-row { display: flex; align-items: center; gap: 6px; font-size: 11px; color: #111; margin-bottom: 14px; line-height: 1.4; }
  .vdp-time-row .red { color: #dc2626; font-weight: 700; }
  .vdp-seller { background: #f6f7f9; border-radius: 8px; padding: 9px 11px; margin-bottom: 10px; }
  .vdp-seller-label { font-size: 8.5px; color: #777; font-weight: 600; }
  .vdp-seller-name { font-size: 10.5px; font-weight: 700; color: #111; margin: 1px 0; }
  .vdp-seller-loc { font-size: 9.5px; color: #666; display: flex; gap: 3px; align-items: center; }
  .vdp-place-big { width: 100%; background: #ff7a1f; color: #fff; border: none; border-radius: 9px; padding: 11px; font-size: 11.5px; font-weight: 700; margin-bottom: 7px; font-family: inherit; }
  .vdp-watch { width: 100%; background: #fff; color: #111; border: 0.5px solid #ddd; border-radius: 9px; padding: 11px; font-size: 11.5px; font-weight: 600; font-family: inherit; margin-bottom: 10px; }
  .vdp-verified { font-size: 9.5px; color: #222; display: flex; align-items: center; gap: 5px; margin-bottom: 3px; font-weight: 500; }
  .vdp-verified-check { color: #2d7a2d; }

  /* Loading overlay */
  .overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.55); display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 280ms ease; padding: 0 18px; z-index: 10; }
  .overlay.on { opacity: 1; pointer-events: auto; }
  .load-card { background: #1c1c1c; border: 0.5px solid rgba(255,255,255,0.06); border-radius: 18px; padding: 24px 18px 22px; width: 100%; text-align: center; transform: scale(0.96); transition: transform 280ms ease; }
  .overlay.on .load-card { transform: scale(1); }
  .load-card h2 { font-size: 18px; font-weight: 500; margin: 0 0 6px; color: #fff; }
  .load-card .hint { font-size: 12px; color: #b5b5b5; margin: 0; }
  .spinner-wrap { width: 50px; height: 50px; margin: 0 auto 14px; position: relative; }
  .spinner-ring { position: absolute; inset: 0; border: 3px solid rgba(255,122,31,0.18); border-top-color: #ff7a1f; border-radius: 50%; animation: spin 0.9s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  @keyframes tapRipple { 0% { transform: translate(-50%,-50%) scale(0); opacity: 0.95; } 100% { transform: translate(-50%,-50%) scale(3.2); opacity: 0; } }

  .controls { display: flex; gap: 10px; align-items: center; }
  .state-label { font-size: 12px; color: #aaa; min-width: 200px; text-align: center; }
  .state-label b { color: #fff; font-weight: 500; }
  .btn { background: transparent; border: 0.5px solid rgba(255,255,255,0.25); color: #fff; padding: 7px 14px; border-radius: 8px; font-size: 12px; cursor: pointer; font-family: inherit; display: inline-flex; align-items: center; gap: 6px; }
  .btn:hover { background: rgba(255,255,255,0.05); }

  /* Chat FAB tap ripple + press */
  .chat-tap-ripple { position: absolute; top: 50%; left: 50%; width: 44px; height: 44px; border-radius: 50%; transform: translate(-50%, -50%) scale(0); border: 2px solid #fff; opacity: 0; pointer-events: none; }
  .chat-tap-ripple.go { animation: chatRipple 0.7s ease-out forwards; }
  @keyframes chatRipple { 0% { transform: translate(-50%,-50%) scale(0); opacity: 0.9; } 100% { transform: translate(-50%,-50%) scale(2); opacity: 0; } }
  .chat-fab.pressed { animation: chatPress 0.35s ease-out; }
  @keyframes chatPress { 0%,100% { transform: scale(1); } 40% { transform: scale(0.88); } }

  /* AI Search Assistant bottom sheet */
  .ai-sheet { position: absolute; bottom: 0; left: 0; right: 0; height: 470px; background: #fff; border: 1.5px solid #ff7a1f; border-bottom: none; border-top-left-radius: 18px; border-top-right-radius: 18px; padding: 16px 16px 12px; transform: translateY(100%); transition: transform 540ms cubic-bezier(0.22, 0.61, 0.36, 1); z-index: 20; display: flex; flex-direction: column; gap: 11px; box-sizing: border-box; }
  .ai-sheet.on { transform: translateY(0); }
  .ai-sheet-head { display: flex; justify-content: space-between; align-items: center; }
  .ai-sheet-title { font-size: 15px; font-weight: 700; color: #111; }
  .ai-sheet-close { color: #555; font-size: 20px; line-height: 1; padding: 2px 4px; }
  .ai-greeting { display: flex; gap: 10px; align-items: flex-start; margin-top: 2px; }
  .ai-greeting-icon { width: 28px; height: 28px; background: #ff7a1f; border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; }
  .ai-greeting-text { font-size: 11px; color: #111; line-height: 1.45; flex: 1; }
  .ai-prompts-label { font-size: 10.5px; color: #555; margin-top: 3px; }
  .ai-prompts { display: flex; flex-direction: column; gap: 7px; }
  .ai-prompt { border: 0.5px solid #d8d8d8; border-radius: 999px; padding: 9px 14px; font-size: 11px; font-weight: 600; color: #111; background: #fff; }
  .ai-input-row { display: flex; gap: 8px; align-items: center; background: #fff; border: 0.5px solid #ddd; border-radius: 999px; padding: 3px 4px 3px 14px; margin-top: 3px; }
  .ai-input-row .ph { flex: 1; font-size: 11px; color: #999; }
  .ai-send { width: 28px; height: 28px; background: rgba(255, 122, 31, 0.42); border-radius: 50%; color: #fff; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .ai-report { background: #fff; border: 0.5px solid #fca5a5; border-radius: 10px; padding: 10px; color: #dc2626; font-size: 11px; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 6px; font-family: inherit; }
  .ai-footer { font-size: 10px; color: #ff7a1f; text-align: center; display: flex; align-items: center; justify-content: center; gap: 4px; font-weight: 500; }
  .ai-footer-brand { font-weight: 700; }
  .ai-footer-icon { display: flex; }

  /* Report a Problem button tap ripple + press */
  .ai-report { position: relative; overflow: hidden; }
  .report-tap-ripple { position: absolute; top: 50%; left: 50%; width: 22px; height: 22px; border-radius: 50%; transform: translate(-50%, -50%) scale(0); border: 1.5px solid #dc2626; background: rgba(220,38,38,0.18); opacity: 0; pointer-events: none; }
  .report-tap-ripple.go { animation: tapRipple 0.7s ease-out forwards; }
  .ai-report.pressed { animation: btnPress 0.4s ease-out; }

  /* Report a Problem bottom sheet — slides in from the right (stack navigation pattern) */
  .report-sheet { position: absolute; bottom: 0; left: 0; right: 0; height: 540px; background: #fff; border: 1.5px solid #ff7a1f; border-bottom: none; border-top-left-radius: 18px; border-top-right-radius: 18px; padding: 16px 16px 12px; transform: translateX(100%); transition: transform 460ms cubic-bezier(0.22, 0.61, 0.36, 1); z-index: 21; display: flex; flex-direction: column; gap: 10px; box-sizing: border-box; }
  .report-sheet.on { transform: translateX(0); }
  .report-head { display: flex; align-items: center; gap: 12px; }
  .report-back { color: #555; padding: 2px; display: flex; }
  .report-title { font-size: 15px; font-weight: 700; color: #111; flex: 1; }
  .report-close { color: #555; padding: 2px; display: flex; }
  .report-greeting { display: flex; gap: 10px; align-items: flex-start; margin-top: 2px; }
  .report-icon { width: 28px; height: 28px; background: #dc2626; border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; }
  .report-greeting-text { font-size: 11px; color: #111; line-height: 1.5; flex: 1; text-align: center; padding: 0 4px; }
  .report-vin-label { font-size: 10.5px; color: #555; margin-top: 2px; line-height: 1.4; }
  .report-vin { background: #fff; border: 0.5px solid #ddd; border-radius: 8px; padding: 11px 14px; font-size: 11px; color: #999; }
  .report-prompts { display: flex; flex-direction: column; gap: 6px; margin-top: 2px; }
  .report-prompt { border: 0.5px solid #d8d8d8; border-radius: 999px; padding: 9px 14px; font-size: 11px; font-weight: 600; color: #111; background: #fff; }
  .report-input-row { display: flex; gap: 8px; align-items: center; background: #fff; border: 0.5px solid #ddd; border-radius: 999px; padding: 3px 4px 3px 14px; margin-top: 4px; }
  .report-input-row .ph { flex: 1; font-size: 11px; color: #999; }
  .report-send { width: 28px; height: 28px; background: rgba(220, 38, 38, 0.38); border-radius: 50%; color: #fff; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

  /* Typing cursor — pseudo-element on the active text span */
  .typing-cursor::after { content: '|'; display: inline-block; margin-left: 1px; color: #111; font-weight: 400; animation: cursorBlink 0.7s steps(2) infinite; }
  @keyframes cursorBlink { 50% { opacity: 0; } }
  /* Typed text states override the muted placeholder color */
  .vin-text.typed { color: #111; font-weight: 600; letter-spacing: 0.3px; }
  .desc-text.typed { color: #111; font-weight: 500; }
  /* Pill selection */
  .report-prompt { transition: background-color 280ms ease, border-color 280ms ease, color 280ms ease; }
  .report-prompt.flash { animation: pillFlash 0.45s ease-out; }
  @keyframes pillFlash { 0%,100% { transform: scale(1); } 45% { transform: scale(0.97); } }
  .report-prompt.selected { background: #fff4f4; border-color: #dc2626; color: #dc2626; }
  /* Send button press */
  .report-send { position: relative; overflow: hidden; transition: background 220ms ease; }
