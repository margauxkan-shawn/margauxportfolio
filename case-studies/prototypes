                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Buffalo, NY
              </div>
            </div>
            <button class="vdp-place-big">Place Bid</button>
            <button class="vdp-watch">Watch Auction</button>
            <div class="vdp-verified"><span class="vdp-verified-check"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg></span>150-Point Inspection Complete</div>
            <div class="vdp-verified"><span class="vdp-verified-check"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Clean Title Verified</div>
          </div>

        </div>
        <div class="chat-fab" id="vdpChatFab">
          <span class="chat-tap-ripple" id="chatTap"></span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          CHAT
        </div>
      </div>
      <div class="bottom-nav">
        <div class="nav-item"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l9-9 9 9"/><path d="M5 10v10a1 1 0 0 0 1 1h3v-7h6v7h3a1 1 0 0 0 1-1V10"/></svg>Home</div>
        <div class="nav-item active"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>Marketplace</div>
        <div class="nav-item"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="12" width="4" height="8"/><rect x="10" y="8" width="4" height="12"/><rect x="17" y="4" width="4" height="16"/></svg>Market</div>
        <div class="nav-item"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a7 7 0 0 1 14 0v1"/></svg>My ACV</div>
        <div class="nav-item"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>Menu</div>
      </div>
      <div class="ai-sheet" id="aiSheet">
        <div class="ai-sheet-head">
          <div class="ai-sheet-title">AI Search Assistant</div>
          <div class="ai-sheet-close">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </div>
        </div>
        <div class="ai-greeting">
          <div class="ai-greeting-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 L13.6 10.4 L22 12 L13.6 13.6 L12 22 L10.4 13.6 L2 12 L10.4 10.4 Z"/></svg>
          </div>
          <div class="ai-greeting-text">Hello! Looking for the perfect vehicle? I'm here to help you find exactly what you need.</div>
        </div>
        <div class="ai-prompts-label">Not sure what to ask? Choose something:</div>
        <div class="ai-prompts">
          <div class="ai-prompt">What's the market value?</div>
          <div class="ai-prompt">Compare to similar vehicles</div>
          <div class="ai-prompt">Show vehicle history report</div>
          <div class="ai-prompt">What's the average days to sell?</div>
        </div>
        <div class="ai-input-row">
          <div class="ph">Ask a question...</div>
          <div class="ai-send">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </div>
        </div>
        <button class="ai-report" id="reportBtn">
          <span class="report-tap-ripple" id="reportTap"></span>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Report a Problem
        </button>
        <div class="ai-footer">
          Powered by
          <span class="ai-footer-icon"><svg width="10" height="10" viewBox="0 0 24 24" fill="#ff7a1f"><path d="M12 2 L13.6 10.4 L22 12 L13.6 13.6 L12 22 L10.4 13.6 L2 12 L10.4 10.4 Z"/></svg></span>
          <span class="ai-footer-brand">ACV AI</span>
        </div>
      </div>
      <div class="report-sheet" id="reportSheet">
        <div class="report-head">
          <span class="report-back">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          </span>
          <div class="report-title">Report a Problem</div>
          <span class="report-close">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </span>
        </div>
        <div class="report-greeting">
          <div class="report-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <div class="report-greeting-text">I'm here to help resolve your issue. Please describe the problem or select from common issues below.</div>
        </div>
        <div class="report-vin-label">You can optionally add a VIN number to help us assist you better:</div>
        <div class="report-vin"><span class="vin-text" id="vinText">Enter VIN</span></div>
        <div class="report-prompts">
          <div class="report-prompt">Vehicle condition doesn't match listing</div>
          <div class="report-prompt">Missing vehicle documentation</div>
          <div class="report-prompt">Auction timing issue</div>
          <div class="report-prompt">Payment or billing problem</div>
          <div class="report-prompt">Transport delay or damage</div>
          <div class="report-prompt">Need to cancel a bid</div>
        </div>
        <div class="report-input-row">
          <div class="ph"><span class="desc-text" id="descText">Describe your problem...</span></div>
          <div class="report-send" id="sendBtn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </div>
        </div>
        <div class="ai-footer">
          Powered by
          <span class="ai-footer-icon"><svg width="10" height="10" viewBox="0 0 24 24" fill="#ff7a1f"><path d="M12 2 L13.6 10.4 L22 12 L13.6 13.6 L12 22 L10.4 13.6 L2 12 L10.4 10.4 Z"/></svg></span>
          <span class="ai-footer-brand">ACV AI</span>
        </div>
      </div>

      <div class="vdp-toast" id="vdpToast">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Problem submitted
      </div>
    </div>

    <!-- Loading overlay -->
    <div class="overlay" id="loading">
      <div class="load-card">
        <div class="spinner-wrap"><div class="spinner-ring"></div></div>
        <h2>Loading...</h2>
        <p class="hint">Opening vehicle details</p>
      </div>
    </div>

  </div>

  <div class="controls">
    <div class="state-label" id="stateLabel"><b>Search results</b> &mdash; idle</div>
    <button class="btn" id="restart">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
      Replay
    </button>
    <button class="btn" id="pause">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      Pause
    </button>
  </div>
</div>

<script>
(function(){
  const results = document.getElementById('results');
  const vdp = document.getElementById('vdp');
  const loading = document.getElementById('loading');
  const vdpTap = document.getElementById('vdpTap');
  const viewBtn = document.getElementById('viewDetailsBtn');
  const vdpBody = document.getElementById('vdpBody');
  const aiSheet = document.getElementById('aiSheet');
  const chatTap = document.getElementById('chatTap');
  const vdpChatFab = document.getElementById('vdpChatFab');
  const reportSheet = document.getElementById('reportSheet');
  const reportTap = document.getElementById('reportTap');
  const reportBtn = document.getElementById('reportBtn');
  const vinText = document.getElementById('vinText');
  const descText = document.getElementById('descText');
  const sendBtn = document.getElementById('sendBtn');
  const vdpToast = document.getElementById('vdpToast');
  const reportPills = document.querySelectorAll('.report-prompt');
  const stateLabel = document.getElementById('stateLabel');
  const restartBtn = document.getElementById('restart');
  const pauseBtn = document.getElementById('pause');

  const playIcon = '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>';
  const pauseIcon = '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>';

  let timers = [];
  let paused = false;

  function setState(name, hint){ stateLabel.innerHTML = '<b>' + name + '</b>' + (hint ? ' &mdash; ' + hint : ''); }
  function clearTimers(){ timers.forEach(clearTimeout); timers = []; }
  function add(fn, ms){ timers.push(setTimeout(fn, ms)); }

  function triggerRipple(){
    vdpTap.classList.remove('go'); void vdpTap.offsetWidth; vdpTap.classList.add('go');
    viewBtn.classList.remove('pressed'); void viewBtn.offsetWidth; viewBtn.classList.add('pressed');
  }

  function triggerChatTap(){
    chatTap.classList.remove('go'); void chatTap.offsetWidth; chatTap.classList.add('go');
    vdpChatFab.classList.remove('pressed'); void vdpChatFab.offsetWidth; vdpChatFab.classList.add('pressed');
  }

  function triggerReportTap(){
    reportTap.classList.remove('go'); void reportTap.offsetWidth; reportTap.classList.add('go');
    reportBtn.classList.remove('pressed'); void reportBtn.offsetWidth; reportBtn.classList.add('pressed');
  }

  function typeInto(el, text, speed){
    el.textContent = '';
    el.classList.add('typed', 'typing-cursor');
    let i = 0;
    function step(){
      if (i < text.length) {
        el.textContent = text.slice(0, i + 1);
        i++;
        timers.push(setTimeout(step, speed));
      }
    }
    step();
  }
  function tapPill(idx){
    const p = reportPills[idx];
    p.classList.remove('flash'); void p.offsetWidth;
    p.classList.add('flash', 'selected');
  }
  function tapSend(){
    sendBtn.classList.remove('pressed'); void sendBtn.offsetWidth;
    sendBtn.classList.add('pressed');
  }

  function reset(){
    results.classList.add('on');
    vdp.classList.remove('on');
    loading.classList.remove('on');
    vdpTap.classList.remove('go');
    viewBtn.classList.remove('pressed');
    vdpBody.classList.remove('s1', 's2', 'slow');
    aiSheet.classList.remove('on');
    chatTap.classList.remove('go');
    vdpChatFab.classList.remove('pressed');
    reportSheet.classList.remove('on');
    reportTap.classList.remove('go');
    reportBtn.classList.remove('pressed');
    vinText.textContent = 'Enter VIN';
    vinText.classList.remove('typed', 'typing-cursor');
    descText.textContent = 'Describe your problem...';
    descText.classList.remove('typed', 'typing-cursor');
    reportPills.forEach(p => p.classList.remove('flash', 'selected'));
    sendBtn.classList.remove('pressed');
    vdpToast.classList.remove('on');
  }

  function play(){
    if (paused) return;
    clearTimers();
    reset();
    setState('Search results', 'idle');

    add(() => { triggerRipple(); setState('Search results', 'tap View Details'); }, 3000);
    add(() => { loading.classList.add('on'); setState('Loading', 'opening vehicle'); }, 3500);
    add(() => { results.classList.remove('on'); vdp.classList.add('on'); }, 3900);
    add(() => { loading.classList.remove('on'); setState('Vehicle details', 'Summary'); }, 4300);
    add(() => { vdpBody.classList.add('s1'); setState('Vehicle details', 'Specs & features'); }, 6100);
    add(() => { vdpBody.classList.remove('s1'); vdpBody.classList.add('s2'); setState('Vehicle details', 'Place a bid'); }, 8300);
    add(() => { vdpBody.classList.add('slow'); vdpBody.classList.remove('s2'); setState('Vehicle details', 'back to summary'); }, 10500);
    add(() => { triggerChatTap(); setState('Vehicle details', 'tap CHAT'); }, 13200);
    add(() => { aiSheet.classList.add('on'); setState('AI Search Assistant', 'opening'); }, 13650);
    add(() => { triggerReportTap(); setState('AI Search Assistant', 'tap Report a Problem'); }, 15000);
    add(() => { reportSheet.classList.add('on'); setState('Report a Problem', 'opening'); }, 15450);
    // Wait for sheet slide (460ms) + brief settle, then type VIN
    add(() => { setState('Report a Problem', 'enter VIN'); typeInto(vinText, 'WBA5B3C51ED123456', 38); }, 16200);
    // VIN typing ~17*38=646ms ends at ~16346; remove cursor after a brief hold
    add(() => { vinText.classList.remove('typing-cursor'); setState('Report a Problem', 'select an issue'); }, 17000);
    // Tap the first pill — "Vehicle condition doesn't match listing"
    add(() => { tapPill(0); setState('Report a Problem', 'issue selected'); }, 17350);
    // Brief beat to let the selected-state register visually, then start typing description
    add(() => { setState('Report a Problem', 'describe issue'); typeInto(descText, "Photos don't show bumper damage", 42); }, 18000);
    // Description typing ~31*42=1302ms ends at ~18802; remove cursor
    add(() => { descText.classList.remove('typing-cursor'); setState('Report a Problem', 'tap send'); }, 19500);
    // Tap send button — press animation + color flash
    add(() => { tapSend(); setState('Report a Problem', 'submitting'); }, 19800);
    // After the send press peaks (~180ms in), dismiss the Report sheet (slides back right)
    add(() => { reportSheet.classList.remove('on'); }, 20250);
    // 150ms stagger — then dismiss the AI sheet (slides back down) so the VDP is revealed
    add(() => { aiSheet.classList.remove('on'); }, 20400);
    // Once both transitions are complete (~540ms for the AI sheet slide), surface
    // the success toast at the bottom of the VDP page
    add(() => { vdpToast.classList.add('on'); setState('Submitted', 'problem reported'); }, 21050);
    // Final hold before the Replay prompt
    add(() => { setState('Done', 'tap Replay to restart'); }, 22300);
  }

  restartBtn.addEventListener('click', () => { paused = false; pauseBtn.innerHTML = pauseIcon + ' Pause'; play(); });
  pauseBtn.addEventListener('click', () => {
    paused = !paused;
    if (paused) { clearTimers(); pauseBtn.innerHTML = playIcon + ' Play'; setState('Paused', ''); }
    else { pauseBtn.innerHTML = pauseIcon + ' Pause'; play(); }
  });

  play();
})();
</script>
</body>
</html>
